{
  "description": "Auto-refresh expired Spotify OAuth tokens before API calls",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-token.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
