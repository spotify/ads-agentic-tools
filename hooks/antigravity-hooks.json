{
  "spotify-ads-token-refresh": {
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${pluginPath}${/}hooks${/}check-token.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
